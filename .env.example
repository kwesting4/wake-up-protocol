# AnythingLLM API Key
# Copy this file to .env and fill in your key
# Get your key from: AnythingLLM → Settings → Developer API → Authorize
ANYTHINGLLM_API_KEY=your-key-here

# AnythingLLM base URL (default for local install)
ANYTHINGLLM_BASE_URL=http://localhost:3001/api

# AnythingLLM workspace slug (the name shown in the workspace URL)
# Default is "my-workspace" — update if your workspace has a different slug
ANYTHINGLLM_WORKSPACE_SLUG=my-workspace
